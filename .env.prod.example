APP_NAME=Fishing Forecast API
APP_ENV=prod
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=json

POSTGRES_DB=forecast
POSTGRES_USER=forecast
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://forecast:change_me@db:5432/forecast
REDIS_URL=redis://redis:6379/0
FORECAST_CACHE_TTL_SEC=300
CATCH_RATE_LIMIT_WINDOW_SEC=60
CATCH_RATE_LIMIT_MAX_REQUESTS=10
CATCH_DUPLICATE_WINDOW_SEC=180
AUTH_JWT_SECRET=change_me_prod_secret
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MIN=120
AUTH_DEMO_USER=demo
AUTH_DEMO_PASSWORD=change_me_demo_password
LOCATION_LAT=55.99
LOCATION_LON=92.88
FORECAST_REGION=krasnoyarsk
FORECAST_FRESHNESS_HOURS=24
ML_RETRAIN_MIN_RECORDS=20
LEGAL_CONTACT_EMAIL=privacy@kvh-forecast.ru
LEGAL_SUPPORT_EMAIL=legal@kvh-forecast.ru
LEGAL_PRIVACY_URL=https://kvh-forecast.ru/privacy
LEGAL_TERMS_URL=https://kvh-forecast.ru/terms
LEGAL_DATA_DELETION_URL=https://kvh-forecast.ru/data-deletion
LEGAL_COOKIE_TRACKING_URL=https://kvh-forecast.ru/cookie-tracking
CORS_ALLOWED_ORIGINS=https://kvh-forecast.ru,https://www.kvh-forecast.ru
